# ==================== Keyway Configuration ====================
# Copy this file to .env and edit. All values shown are defaults.

# ---- Server ----
KEYWAY_HOST=127.0.0.1
KEYWAY_PORT=9233
KEYWAY_LOG_LEVEL=info

# ---- Admin token (for the management UI / admin API) ----
# If left empty, a random token is generated on first start and printed
# to the console. Copy it to use the web admin UI.
# Set a fixed value for reproducible deployments (e.g. Docker).
KEYWAY_ADMIN_TOKEN=

# ---- Encryption secret (CRITICAL) ----
# Used to encrypt all at-rest secrets (provider API keys, tool keys,
# self-issued db_sk_ key plaintexts) via Fernet. MUST be a strong random
# string. If left empty, the server refuses to start.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
KEYWAY_SECRET=

# ---- Data directory ----
# Where keyway.db (SQLite) is stored. Defaults to ./data next to this file.
KEYWAY_DATA_DIR=

# ---- CORS ----
# Comma-separated list of allowed origins for the admin UI.
KEYWAY_CORS_ORIGINS=http://127.0.0.1:9233,http://localhost:9233

# ---- Public base URL (shown to users in the admin UI for key setup) ----
# If empty, the server infers it from the incoming request host.
KEYWAY_PUBLIC_BASE_URL=
